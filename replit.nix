# БЛОК ОПРЕДЕЛЕНИЯ ЗАВИСИМОСТЕЙ ПРОЕКТА (NIX)
# { pkgs }: - это функция, которая принимает пакеты Nix как аргумент
# pkgs - это коллекция всех доступных пакетов в Nixpkgs
{ pkgs }: {
  # БЛОК СПИСКА ЗАВИСИМОСТЕЙ (DEPS)
  # deps - список системных зависимостей, которые будут установлены
  # в окружение Replit
  deps = [
    # ПЕРВАЯ ЗАВИСИМОСТЬ: prybar-python310
    # pkgs.replitPackages.prybar-python310
    # Назначение: Prybar - это мост (bridge) между Python и другими 
    # компонентами Replit. Он позволяет:
    #   - Запускать интерпретатор Python с определёнными настройками
    #   - Взаимодействовать с системой Replit
    #   - Обеспечивать совместимость между различными версиями Python
    # Версия 3.10 означает, что используется Python 3.10
    pkgs.replitPackages.prybar-python310
    # ВТОРАЯ ЗАВИСИМОСТЬ: stderred
    # pkgs.replitPackages.stderred
    # Назначение: stderred - это библиотека, которая перехватывает 
    # вывод в stderr (стандартный поток ошибок) и окрашивает его 
    # в красный цвет для лучшей видимости.
    # Полезно при отладке, так как ошибки становятся заметнее
    # в консоли Replit.
    pkgs.replitPackages.stderred
  ];
}